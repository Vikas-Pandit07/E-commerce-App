### Order Processing Flow

```sql
-- Step 1: View New Orders
SELECT * FROM orders WHERE order_status = 'PENDING' ORDER BY order_date;

-- Step 2: Confirm Order (Update Status)
UPDATE orders SET order_status = 'CONFIRMED' WHERE order_id = 123;

-- Step 3: Process Payment Verification
-- Check if payment is successful via Razorpay dashboard

-- Step 4: Update Payment Status
UPDATE orders SET payment_status = 'PAID' WHERE order_id = 123;

-- Step 5: Prepare for Shipping
UPDATE orders SET order_status = 'PROCESSING' WHERE order_id = 123;

-- Step 6: Generate Invoice
-- (Invoices are automatically generated)

-- Step 7: Pack and Ship
UPDATE orders SET 
    order_status = 'SHIPPED',
    tracking_number = 'shipping_tracking_number',
    shipping_partner = 'delivery_partner'
WHERE order_id = 123;

-- Step 8: Mark Delivered
UPDATE orders SET 
    order_status = 'DELIVERED',
    delivered_at = NOW()
WHERE order_id = 123;
```

### Inventory Management

```sql
-- 1. View Inventory Levels
SELECT 
    p.product_id,
    p.name,
    p.stock,
    p.reorder_point,
    CASE 
        WHEN p.stock <= p.reorder_point THEN 'REORDER'
        WHEN p.stock <= 10 THEN 'LOW'
        ELSE 'GOOD'
    END as stock_status
FROM products p
WHERE p.status = 'ACTIVE'
ORDER BY stock ASC;

-- 2. Update Stock After Purchase
UPDATE products 
SET stock = stock - 1 
WHERE product_id = 123;

-- 3. Reorder Products
-- When stock < reorder_point, create purchase order
```

### Daily Reports

```sql
-- 1. Daily Sales Report
SELECT 
    DATE(order_date) as date,
    COUNT(*) as orders,
    SUM(total_amount) as revenue,
    AVG(total_amount) as avg_order_value
FROM orders 
WHERE payment_status = 'PAID' 
AND order_date >= CURDATE() - INTERVAL 7 DAY
GROUP BY DATE(order_date)
ORDER BY date DESC;

-- 2. Top Selling Products
SELECT 
    p.product_id,
    p.name,
    SUM(oi.quantity) as total_sold,
    SUM(oi.total_price) as total_revenue
FROM order_items oi
JOIN orders o ON oi.order_id = o.order_id
JOIN products p ON oi.product_id = p.product_id
WHERE o.payment_status = 'PAID'
GROUP BY p.product_id, p.name
ORDER BY total_sold DESC
LIMIT 10;

-- 3. Customer Statistics
SELECT 
    COUNT(DISTINCT user_id) as total_customers,
    COUNT(CASE WHEN created_at > CURDATE() - INTERVAL 30 DAY THEN 1 END) as new_customers,
    COUNT(CASE WHEN created_at > CURDATE() - INTERVAL 7 DAY THEN 1 END) as weekly_new
FROM users
WHERE role = 'CUSTOMER';
```

