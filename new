        StringBuilder sb = new StringBuilder();
        if (size != null) sb.append("Size: ").append(size);
        if (color != null) {
            if (!sb.isEmpty()) sb.append(" | ");
            sb.append("Color: ").append(color);
        }
        return sb.isEmpty() ? "Default" : sb.toString();
    }

    public void addStock(int quantity) {
        this.stockQuantity += quantity;
    }

    public void deductStock(int quantity) {
        if (this.stockQuantity - quantity < 0) {
            throw new IllegalStateException("Insufficient stock for variant: " + sku);
        }
        this.stockQuantity -= quantity;
    }

    public void reserveStock(int quantity) {
        if (getAvailableQuantity() < quantity) {
            throw new IllegalStateException("Cannot reserve " + quantity + " units of " + sku + ". Available: " + getAvailableQuantity());
        }
        this.reservedQuantity += quantity;
    }

    public void releaseReservation(int quantity) {
        this.reservedQuantity = Math.max(0, this.reservedQuantity - quantity);
    }
